# itihas — civilizations (53)

enum CivOff { CIV_NAME=0; CIV_REGION=8; CIV_PEAK=16; CIV_FOUND=24; CIV_END=32; CIV_TRAITS=40; CIV_SCRIPT=48; CIV_LANG=56; CIV_SIZE=64; }

var civ_vec = 0;
var civ_init_done = 0;

fn civ_new(name: Str, region: Str, peak: Str, fy, ey, traits: Str, script: Str, lang: Str) {
    var p = alloc(CIV_SIZE);
    store64(p+CIV_NAME, name); store64(p+CIV_REGION, region); store64(p+CIV_PEAK, peak);
    store64(p+CIV_FOUND, fy); store64(p+CIV_END, ey);
    store64(p+CIV_TRAITS, traits); store64(p+CIV_SCRIPT, script); store64(p+CIV_LANG, lang);
    return p;
}
fn civ_name(p) { return load64(p+CIV_NAME); }
fn civ_region(p) { return load64(p+CIV_REGION); }
fn civ_found(p) { return load64(p+CIV_FOUND); }
fn civ_end(p) { return load64(p+CIV_END); }

