}

fn all_civilizations() {
    if (civ_init_done == 0) { civ_vec = build_civs(); civ_init_done = 1; }
    return civ_vec;
}
fn civ_count() { return vec_len(all_civilizations()); }
fn civ_get(idx) { return vec_get(all_civilizations(), idx); }

fn civs_by_region(region: Str) {
    var result = vec_new();
    var v = all_civilizations(); var n = vec_len(v);
    for (var i = 0; i < n; i = i + 1) {
        var p = vec_get(v, i);
        if (str_contains(civ_region(p), region) == 1) { vec_push(result, p); }
    }
    return result;
}

fn _cmp_civ_found(a, b) { return load64(a+CIV_FOUND) - load64(b+CIV_FOUND); }

fn civs_active_at(year) {
    var result = vec_new();
    var v = all_civilizations(); var n = vec_len(v);
    for (var i = 0; i < n; i = i + 1) {
        var p = vec_get(v, i);
        if (year >= civ_found(p) && year <= civ_end(p)) { vec_push(result, p); }
    }
    vec_sort(result, &_cmp_civ_found);
    return result;
}

fn civ_by_name(name: Str) {
    var v = all_civilizations(); var n = vec_len(v);
    for (var i = 0; i < n; i = i + 1) {
        var p = vec_get(v, i);
        if (str_eq_lower(civ_name(p), name) == 1) { return p; }
    }
    return 0;
}
