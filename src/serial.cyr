# ----------------------------------------------------------------
# Campaign (with nested battles array)
# ----------------------------------------------------------------
fn battle_to_json(b) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    _json_str(sb, "name", load64(b+BAT_NAME));
    _json_sep(sb); _json_int(sb, "year", load64(b+BAT_YEAR));
    _json_sep(sb); _json_str(sb, "location", load64(b+BAT_LOC));
    _json_sep(sb); _json_str(sb, "description", load64(b+BAT_DESC));
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

fn campaign_to_json(p) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    _json_str(sb, "name", load64(p+CAMP_NAME));
    _json_sep(sb); _json_str(sb, "region", load64(p+CAMP_REGION));
    _json_sep(sb); _json_int(sb, "start_year", load64(p+CAMP_START));
    _json_sep(sb); _json_int(sb, "end_year", load64(p+CAMP_END));
    _json_sep(sb); _json_str(sb, "belligerents_a", load64(p+CAMP_BELLA));
    _json_sep(sb); _json_str(sb, "belligerents_b", load64(p+CAMP_BELLB));
    _json_sep(sb); _json_str(sb, "commanders", load64(p+CAMP_CMDS));
    _json_sep(sb); _json_int(sb, "outcome", load64(p+CAMP_OUT));
    _json_sep(sb); _json_str(sb, "description", load64(p+CAMP_DESC));
    # Battles array
    _json_sep(sb);
    str_builder_add_cstr(sb, "\"battles\": [");
    var bats = load64(p+CAMP_BATTLES);
    var bn = vec_len(bats);
    for (var bi = 0; bi < bn; bi = bi + 1) {
        if (bi > 0) { str_builder_add_cstr(sb, ", "); }
        str_builder_add(sb, battle_to_json(vec_get(bats, bi)));
    }
    str_builder_add_cstr(sb, "]");
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

