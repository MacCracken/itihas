    str_builder_add_cstr(sb, "{");
    _json_str(sb, "civilization_a", load64(p+INT_CIVA));
    _json_sep(sb); _json_str(sb, "civilization_b", load64(p+INT_CIVB));
    _json_sep(sb); _json_int(sb, "type", load64(p+INT_TYPE));
    _json_sep(sb); _json_int(sb, "start_year", load64(p+INT_START));
