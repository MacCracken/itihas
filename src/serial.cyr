# serial.cyr — JSON serialization for all itihas types
# Uses str_builder from stdlib. Requires json.cyr for json_pair_new/json_build.

# ----------------------------------------------------------------
# JSON string escaping helper
# ----------------------------------------------------------------
fn _json_str(sb, key, val: Str) {
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    str_builder_add_cstr(sb, "\": \"");
    # Escape backslashes, quotes, newlines in val
    var vlen = str_len(val);
    var vd = str_data(val);
    var ji = 0;
    while (ji < vlen) {
        var c = load8(vd + ji);
        if (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        else { if (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        else { if (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        else { str_builder_add_byte(sb, c); } } }
        ji = ji + 1;
    }
    str_builder_add_cstr(sb, "\"");
    return 0;
}

fn _json_int(sb, key, val) {
    str_builder_add_cstr(sb, "\"");
    str_builder_add_cstr(sb, key);
    str_builder_add_cstr(sb, "\": ");
    str_builder_add_int(sb, val);
    return 0;
}

fn _json_sep(sb) { str_builder_add_cstr(sb, ", "); return 0; }

# ----------------------------------------------------------------
# Era
# ----------------------------------------------------------------
fn era_to_json(p) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    _json_str(sb, "name", load64(p+ERA_NAME));
    _json_sep(sb); _json_int(sb, "start_year", load64(p+ERA_START));
    _json_sep(sb); _json_int(sb, "end_year", load64(p+ERA_END));
    _json_sep(sb); _json_str(sb, "region", load64(p+ERA_REGION));
    _json_sep(sb); _json_str(sb, "description", load64(p+ERA_DESC));
    _json_sep(sb); _json_int(sb, "category", load64(p+ERA_CAT));
    _json_sep(sb); _json_int(sb, "scope", load64(p+ERA_SCOPE));
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

# ----------------------------------------------------------------
# Civilization
# ----------------------------------------------------------------
fn civ_to_json(p) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    _json_str(sb, "name", load64(p+CIV_NAME));
    _json_sep(sb); _json_str(sb, "region", load64(p+CIV_REGION));
    _json_sep(sb); _json_str(sb, "peak_era", load64(p+CIV_PEAK));
    _json_sep(sb); _json_int(sb, "founded", load64(p+CIV_FOUND));
    _json_sep(sb); _json_int(sb, "ended", load64(p+CIV_END));
    _json_sep(sb); _json_str(sb, "traits", load64(p+CIV_TRAITS));
    _json_sep(sb); _json_str(sb, "script", load64(p+CIV_SCRIPT));
    _json_sep(sb); _json_str(sb, "language", load64(p+CIV_LANG));
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

